# Supabase Configuration (Required for file uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=excel-files

# Optional: Authentication (if you want login)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: CORS configuration
# CORS_ALLOWED_ORIGINS=https://your-frontend.com

# Optional: Shared folder link
# SHARED_FOLDER_URL=https://drive.google.com/...

# Server port
PORT=3000

# Local workbook directory (used when Supabase is not configured)
WORKBOOKS_DIR=workbooks